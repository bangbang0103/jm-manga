# JM
JM_PASSWORD_ENCRYPTION_KEY=
CLIENT_IMPL=api
JM_DOMAIN_LIST=
PROXY=

# 服务
API_TOKEN=
HOST=0.0.0.0
PORT=8000
ENV=development
LOG_LEVEL=INFO
NETWORK_MODE=auto
MDNS_ENABLED=true
