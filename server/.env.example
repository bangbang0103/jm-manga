WEB_DIR=./web

# 存储
DB_PATH=$HOME/.jm-manga/app.db
CACHE_DIR=$HOME/.jm-manga/cache

# 并发
JM_CONCURRENCY=5
IMAGE_CONCURRENCY=3

# 图片签名
IMAGE_TOKEN_TTL=3600
IMAGE_SIGN_SECRET=
